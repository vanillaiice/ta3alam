<%= form_with model: [ klass, assignment ],
  html: { multipart: true }, class: "flex justify-center" do |f| %>
  <fieldset class="fieldset bg-base-200 border-base-300 rounded-box border p-4 w-xl">
    <%= f.label :title, t("assignments.attributes.title"), class: "label" %>
    <%= f.text_field :title, class: "input w-full" %>

    <%= f.label :description, t("assignments.attributes.description"), class: "label" %>
    <%= f.rich_text_area :description, class: "input w-full" %>

    <%= f.label :file, t("shared.attributes.file"), class: "label" %>
    <%= f.file_field :file, class: "file-input w-full" %>

    <%= f.label :accept_content_types, t("assignments.attributes.accept_content_types"), class: "label" %>
    <%= f.select :accept_content_types,
        options_for_select(
          [
            [t("shared.file_types.pdf"), "application/pdf"],
            [t("shared.file_types.docx"), "application/vnd.openxmlformats-officedocument.wordprocessingml.document"],
            [t("shared.file_types.zip"), "application/zip"],
            [t("shared.file_types.image"), "image/png"],
            [t("shared.file_types.text"), "text/plain"],
            [t("shared.file_types.audio"), "audio/*"]
          ],
          assignment.accept_content_types
        ),
        {},
        { multiple: true, class: "w-full h-full" } %>
    <%= f.label t("shared.labels.multi_select_hint"), class: 'label' %>

    <%= f.label :deadline, t("assignments.attributes.deadline"), class: "label" %>
    <%= f.datetime_field :deadline, class: "input w-full" %>

    <%= f.label :max_score, t("assignments.attributes.max_score"), class: "label" %>
    <%= f.number_field :max_score, class: "input w-full" %>

    <%= f.label :weight, t("assignments.attributes.weight"), class: "label" %>
    <%= f.number_field :weight, step: :any, class: "input w-full" %>

    <% if assignment.errors.any? %>
      <span class="text-error"><%= t("errors.template.header", count: assignment.errors.count) %>:</span>
      <ul>
        <% assignment.errors.full_messages.each do |msg| %>
          <li class="text-error"><%= msg %></li>
        <% end %>
      </ul>
    <% end %>

    <%= f.submit class: "btn btn-neutral mt-2" %>

    <%= link_to t("shared.buttons.cancel"), :back, class: 'btn btn-error mt-2' %>
  </fieldset>
<% end %>
