<div class="flex justify-between gap-1">
  <%= render "shared/search", url: [ :courses ] %>
  <% if policy(Course).new? %>
    <%= btn_link [ :new, :course ], nil, icon: :add, classes: 'btn' %>
  <% end %>
</div>

<div class="divider"></div>

<div id="courses">
  <%= render "shared/display_items", items: @courses do |course| %>
    <div class="flex flex-col">
      <%= tag.span "#{course.name} #{course.number}", class: 'text-xl' %>

      <%= course.description if course.description? %>

      <div class="flex justify-between mt-2">
        <section class="flex gap-1">
          <%= link_to "Classes", [ course, :klasses ], class: 'btn btn-sm btn-neutral' %>
          <%= btn_link course, "Details", icon: :subject, classes: "btn btn-sm" %>
        </section>

        <section class="flex gap-1">
          <%= btn_link [ :edit, course], nil, icon: :edit, outlined: true, classes: 'btn-sm' if policy(course).edit? %>
          <% if policy(course).destroy? %>
            <%= button_to course, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: 'btn btn-error btn-sm' do %>
              <%= mi "delete", outlined: true %>
            <% end %>
          <% end %>
        </section>
      </div>
    </div>
  <% end %>
</div>
