<%= tag.h1 "#{@course.name} #{@course.number}", class: 'text-2xl' %>
<%= @course.description if @course.description? %>

<section class="flex gap-1 mt-2">
  <%= link_to "Classes", course_klasses_path(@course), class: 'btn btn-neutral' %>
  <%= btn_link [ :edit, @course ], nil, icon: :edit if policy(@course).edit? %>
  <% if policy(@course).destroy? %>
    <%= button_to @course, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: 'btn btn-error' do %>
      <%= mi "delete", outlined: true %>
    <% end %>
  <% end %>
</section>
