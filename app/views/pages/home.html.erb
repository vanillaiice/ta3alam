<div class="hero min-h-[70vh] bg-base-100">
  <div class="hero-content text-center flex-col">
    <div class="max-w-2xl">
      <h1 class="text-5xl font-bold tracking-tight text-base-content">
        Welcome to Ta3alam
      </h1>
      <p class="py-6 text-lg text-base-content/80">
        The unified platform for teaching and learning. Seamlessly manage your courses, distribute assignments, and track class progress all in one place.
      </p>
      <div class="flex justify-center gap-4 mt-4">
        <% if authenticated? %>
          <%= link_to "Go to Dashboard", d_root_path, class: "btn btn-primary" %>
        <% else %>
          <%= link_to "Log In", new_session_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="bg-base-200 py-16">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-semibold text-center mb-12">Everything you need to succeed</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body">
          <h3 class="card-title text-primary">Course Management</h3>
          <p class="text-base-content/80 mt-2">
            Organize your classes with structured modules, comprehensive lesson contents, and simple scheduling.
          </p>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body">
          <h3 class="card-title text-primary">Assignments & Grading</h3>
          <p class="text-base-content/80 mt-2">
            Create assignments, accept student submissions in various formats, and provide meaningful feedback directly.
          </p>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body">
          <h3 class="card-title text-primary">Stay Connected</h3>
          <p class="text-base-content/80 mt-2">
            Keep everyone on the same page with class announcements, synchronized rosters, and active communication.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<footer class="footer footer-center p-10 bg-base-100 text-base-content border-t border-base-200 mt-auto">
  <aside>
    <p>Copyright © <%= Time.current.year %> - All rights reserved by Ta3alam</p>
  </aside>
</footer>
