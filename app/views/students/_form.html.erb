<%= form_with url: klass_students_path(@klass), scope: :student, class: "flex justify-center" do |f| %>
  <fieldset class="fieldset bg-base-200 border-base-300 rounded-box border p-4 min-w-sm">
    <%= f.label :student, t("students.attributes.user"), class: "label" %>
    <%= f.collection_select :id, 
        User.where(role: :student),
        :id, 
        :name,
        { include_hidden: false, prompt: t("students.labels.select_student") }, 
        { class: "select select-bordered w-full" } %>

    <% if student.errors.any? %>
      <span class="text-error"><%= t("errors.template.header", count: student.errors.count) %>:</span>
      <ul>
        <% student.errors.full_messages.each do |msg| %>
          <li class="text-error"><%= msg %></li>
        <% end %>
      </ul>
    <% end %>

    <%= f.submit t("students.new.submit"), class: "btn btn-neutral mt-2" %>

    <%= link_to t("shared.buttons.cancel"), :back, class: 'btn btn-error mt-2' %>
  </fieldset>
<% end %>
