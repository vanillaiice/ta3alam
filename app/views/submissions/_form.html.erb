<%= form_with model: submission.persisted? ? [ klass, submission ] : [ klass, submission.assignment, submission ],
  html: { multipart: true }, class: "flex justify-center" do |f| %>
  <fieldset class="fieldset bg-base-200 border-base-300 rounded-box border p-4 w-xl">
    <div data-controller="audio-recorder">
      <%= f.label :submission_file, "File (Upload or Record Audio)", class: "label" %>
      <div class="flex items-center gap-2 mb-2">
        <button type="button" data-action="audio-recorder#start" data-audio-recorder-target="recordButton" class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
          </svg>
          Record Audio
        </button>
        <button type="button" data-action="audio-recorder#stop" data-audio-recorder-target="stopButton" class="btn btn-error btn-sm hidden">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9.563C9 9.252 9.252 9 9.563 9h4.874c.311 0 .563.252.563.563v4.874c0 .311-.252.563-.563.563H9.563A.563.563 0 0 1 9 14.437V9.563Z" />
          </svg>
          Stop Recording
        </button>
        <span data-audio-recorder-target="status" class="text-sm font-medium"></span>
      </div>
      <audio data-audio-recorder-target="audioPlayback" controls class="hidden w-full mb-2"></audio>
      <%= f.file_field :submission_file, class: "file-input w-full", accept: submission.assignment.accept_content_types&.join(","), data: { audio_recorder_target: "fileInput" } %>
    </div>

    <%= f.label :notes, "Notes", class: "label" %>
    <%= f.rich_text_area :notes, class: "input w-full" %>

    <% if submission.errors.any? %>
      <span class="text-error">error:</span>
      <ul>
        <% submission.errors.full_messages.each do |msg| %>
          <li class="text-error"><%= msg %></li>
        <% end %>
      </ul>
    <% end %>

    <%= tag.btn f.submit, class: "btn btn-neutral mt-2" %>

    <%= link_to "Cancel", :back, class: 'btn btn-error mt-2' %>
  </fieldset>
<% end %>
