<div class="flex flex-col gap-1">
  <h1 class="flex items-center gap-2">
    <%= tag.span @submission.assignment.title, class: 'font-bold text-secondary text-2xl' %>
    <%= tag.span "#{@submission.score || ''}/#{@submission.assignment.max_score}", class: 'badge badge-lg badge-secondary' %>
    <%= tag.span "x#{@submission.assignment.weight}", class: 'badge badge-lg badge-secondary badge-soft' %>
    <%= link_to "Grade", [ :grade, @klass, @submission ], class: 'btn btn-sm btn-accent' if policy(@submission).grade? %>
  </h1>

  <section class="flex gap-1">
    <%= tag.span @submission.user.name, class: 'badge badge-secondary' %>
  </section>

  <%= @submission.assignment.description if @submission.assignment.description? %>

  <%= tag.span l(@submission.created_at, format: :long), class: "text-sm opacity-60" %>
</div>

<div class="divider"></div>

<turbo-frame id="submission_tab">
  <section class="flex gap-2 items-center">
    <%= link_to "Submission",
      [ @klass, @submission, { t: "submission" } ],
      data: { turbo_frame: "submission_tab", turbo_action: "advance" },
      class: "#{params[:t] != 'feedback' ? 'font-semibold text-secondary text-xl' : 'opacity-60'}" %>

    <%= link_to "Feedback",
      [ @klass, @submission, { t: "feedback" } ],
      data: { turbo_frame: "submission_tab", turbo_action: "advance" },
      class: "#{params[:t] == 'feedback' ? 'font-semibold text-secondary text-xl' : 'opacity-60'}" %>
  </section>

  <%= render "submissions/tabs/#{params[:t] || 'submission'}", submission: @submission %>
</turbo-frame>
