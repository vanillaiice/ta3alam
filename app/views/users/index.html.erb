<div class="flex justify-between gap-1 my-4 mx-2 w-full md:w-4/6">
  <%= render "shared/search", url: users_path %>
  <%= btn_link [ :new, :user ], nil, icon: :add, classes: 'btn btn-primary' %>
</div>

<div class="overflow-x-auto bg-base-100 rounded-box shadow w-full md:w-4/6">
  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <th><%= t("users.new.name") %></th>
        <th><%= t("users.new.email") %></th>
        <th><%= t("users.new.role") %></th>
      </tr>
    </thead>
    <tbody>
      <% if @users.any? %>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email_address %></td>
            <td><span class="badge badge-secondary badge-soft"><%= user.role %></span></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="3" class="text-center py-4 opacity-80"><%= t("shared.labels.no_items") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4 flex justify-center">
  <%= paginate @users, window: 2, params: request.query_parameters %>
</div>
