<%= render "shared/form_container" do %>
  <%= form_with model: @user, url: users_path, class: "flex flex-col gap-4 w-sm" do |f| %>
    <fieldset class="fieldset bg-base-200 border-base-300 rounded-box border p-4">
      <legend class="fieldset-legend text-xl"><%= t("users.new.title") %></legend>

      <label class="label" for="user_name"><%= t("users.new.name") %></label>
      <%= f.text_field :name, class: "input w-full", placeholder: t("users.new.name"), required: true %>

      <label class="label" for="user_email_address"><%= t("users.new.email") %></label>
      <%= f.email_field :email_address, class: "input w-full", placeholder: "user@example.com", required: true %>

      <label class="label" for="user_role"><%= t("users.new.role") %></label>
      <%= f.select :role, User.roles.keys.map { |r| [r.capitalize, r] },
            { include_blank: t("users.new.select_role") },
            class: "select w-full", required: true %>

      <% if @user.errors.any? %>
        <ul class="mt-2">
          <% @user.errors.full_messages.each do |msg| %>
            <li class="text-error text-sm"><%= msg %></li>
          <% end %>
        </ul>
      <% end %>

      <div class="flex gap-2 mt-4">
        <%= f.submit t("users.new.send_invite"), class: "btn btn-primary" %>
        <%= link_to t("users.new.cancel"), users_path, class: "btn btn-ghost" %>
      </div>
    </fieldset>
  <% end %>
<% end %>
