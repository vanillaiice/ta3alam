<%= render "shared/form_container" do %>
  <%= form_with model: @user, url: users_path, class: "flex flex-col gap-4 w-sm" do |f| %>
    <fieldset class="fieldset bg-base-200 border-base-300 rounded-box border p-4">
      <legend class="fieldset-legend text-xl">Invite New User</legend>

      <label class="label" for="user_name">Name</label>
      <%= f.text_field :name, class: "input w-full", placeholder: "Full name", required: true %>

      <label class="label" for="user_email_address">Email</label>
      <%= f.email_field :email_address, class: "input w-full", placeholder: "user@example.com", required: true %>

      <label class="label" for="user_role">Role</label>
      <%= f.select :role, User.roles.keys.map { |r| [r.capitalize, r] },
            { include_blank: "Select a role" },
            class: "select w-full", required: true %>

      <% if @user.errors.any? %>
        <ul class="mt-2">
          <% @user.errors.full_messages.each do |msg| %>
            <li class="text-error text-sm"><%= msg %></li>
          <% end %>
        </ul>
      <% end %>

      <div class="flex gap-2 mt-4">
        <%= f.submit "Send Invite", class: "btn btn-primary" %>
        <%= link_to "Cancel", users_path, class: "btn btn-ghost" %>
      </div>
    </fieldset>
  <% end %>
<% end %>
